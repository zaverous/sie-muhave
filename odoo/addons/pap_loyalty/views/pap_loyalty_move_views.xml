<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List / Tree view -->
    <record id="pap_loyalty_move_view_tree" model="ir.ui.view">
        <field name="name">pap.loyalty.move.tree</field>
        <field name="model">pap.loyalty.move</field>
        <field name="arch" type="xml">
            <tree string="Loyalty Moves">
                <field name="date"/>
                <field name="reference"/>
                <field name="partner_id"/>
                <field name="move_type"/>
                <field name="points"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="pap_loyalty_move_view_form" model="ir.ui.view">
        <field name="name">pap.loyalty.move.form</field>
        <field name="model">pap.loyalty.move</field>
        <field name="arch" type="xml">
            <form string="Loyalty Move">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="reference"/>
                            <field name="partner_id"/>
                            <field name="sale_order_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="move_type"/>
                            <field name="points"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_pap_loyalty_move" model="ir.actions.act_window">
        <field name="name">Loyalty Moves</field>
        <field name="res_model">pap.loyalty.move</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Top-level menu -->
    <menuitem
        id="menu_pap_loyalty_root"
        name="Fidelización"
        sequence="90"
        web_icon="pap_loyalty,static/description/icon.png"/>

    <!-- Sub-menu -->
    <menuitem
        id="menu_pap_loyalty_moves"
        name="Movimientos"
        parent="menu_pap_loyalty_root"
        action="action_pap_loyalty_move"
        sequence="10"/>

</odoo>
